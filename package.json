{
  "name": "study-with-me",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "vercel-build": "node scripts/vercel-build.js",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:setup": "docker compose up -d postgres && sleep 3 && prisma migrate dev --name init",
    "db:reset-analytics": "tsx scripts/reset-analytics.ts",
    "db:vercel-pull": "vercel env pull .env.vercel",
    "db:vercel-migrate": "node -r dotenv/config scripts/vercel-migrate.js dotenv_config_path=.env.vercel"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^6.19.3",
    "pusher": "^5.3.4",
    "pusher-js": "^8.5.0",
    "razorpay": "^2.9.6",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
