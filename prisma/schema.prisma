generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth models ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App models ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isPremium     Boolean   @default(false)
  totalHours    Float     @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  lastStudiedAt DateTime?
  plantStage    Int       @default(0)
  plantXP       Int       @default(0)
  aiUsageCount  Int       @default(0)
  aiUsageReset  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  studySessions StudySession[]
  habits        Habit[]
  labels        Label[]
  goals         Goal[]
  groupMembers  GroupMember[]
  messages      Message[]
  settings      UserSettings?
  pushSubscriptions PushSubscription[]
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String  @default("cosmic")
  fontSize        String  @default("medium")
  darkMode        Boolean @default(true)
  defaultMode     String  @default("pomodoro")
  defaultDuration Int     @default(1500)
  workDuration    Int     @default(1500)
  breakDuration   Int     @default(300)
  autoStartBreaks Boolean @default(false)
  pushEnabled     Boolean @default(false)
}

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  duration  Int
  mode      String
  labelId   String?
  label     Label?   @relation(fields: [labelId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Label {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  color         String
  studySessions StudySession[]

  @@index([userId])
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  targetDays  Int[]
  completedAt DateTime[]
  streak      Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Goal {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  targetHrs Float
  deadline  DateTime?
  progress  Float     @default(0)
  createdAt DateTime  @default(now())

  @@index([userId])
}

model StudyGroup {
  id          String        @id @default(cuid())
  name        String
  description String?
  isPublic    Boolean       @default(true)
  createdById String
  members     GroupMember[]
  messages    Message[]
  timer       GroupTimer?
  createdAt   DateTime      @default(now())
}

model GroupMember {
  id      String     @id @default(cuid())
  userId  String
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId String
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role    String     @default("member")

  @@unique([userId, groupId])
}

model Message {
  id        String     @id @default(cuid())
  groupId   String
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())

  @@index([groupId, createdAt])
}

model OnlinePresence {
  id       String   @id @default(cuid())
  userId   String   @unique
  lastSeen DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model GroupTimer {
  id          String     @id @default(cuid())
  groupId     String     @unique
  group       StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  duration    Int        @default(1500)
  remaining   Int        @default(1500)
  isRunning   Boolean    @default(false)
  startedAt   DateTime?
  startedById String?
  updatedAt   DateTime   @updatedAt
}
